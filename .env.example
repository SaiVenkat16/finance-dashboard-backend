# ──────────────────────────────────────────────
# Finance Dashboard Backend — Environment Config
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/finance_dashboard"

# JWT Secret — use a long, random string in production
JWT_SECRET=your-very-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Bcrypt password hashing rounds (10-12 is recommended)
BCRYPT_ROUNDS=10
